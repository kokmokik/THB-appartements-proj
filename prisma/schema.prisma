generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Property {
  id              String          @id @default(cuid())
  slug            String          @unique
  name            String
  type            String          // "zimmer" | "apartment"
  description     String
  shortDesc       String
  maxGuests       Int
  bedrooms        Int
  bathrooms       Int
  size            Int             // square meters
  pricePerNight   Float
  amenities       String          // JSON string array
  images          String          // JSON string array of image paths
  thumbnail       String
  sortOrder       Int             @default(0)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  bookings        Booking[]
  blockedDates    BlockedDate[]
  rentalInquiries RentalInquiry[]
}

model Booking {
  id              String   @id @default(cuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  totalPrice      Float
  guestName       String
  guestEmail      String
  guestPhone      String
  specialRequests String?
  status          String   @default("pending") // pending, confirmed, cancelled, completed
  stripePaymentId String?
  stripeSessionId String?
  paymentStatus   String   @default("unpaid") // unpaid, deposit_paid, paid, refunded
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  date       DateTime
  reason     String?
  createdAt  DateTime @default(now())
}

model RentalInquiry {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  name       String
  email      String
  phone      String
  moveInDate DateTime
  duration   String   // "6-monate", "1-jahr", "2-jahre", "unbefristet"
  occupants  Int
  message    String?
  status     String   @default("new") // new, contacted, confirmed, rejected
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}
